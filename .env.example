DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Switch database profile any time: local or prod
DB_PROFILE=prod

# ---------------------------
# Local database configuration
# ---------------------------
LOCAL_DB_ENGINE=mysql
LOCAL_DB_NAME=your_local_db_name
LOCAL_DB_USER=your_local_db_user
LOCAL_DB_PASSWORD=your_local_db_password
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=3306
LOCAL_DB_SSL_CA=
LOCAL_DB_CONN_MAX_AGE=60

# -------------------------------
# Production database configuration
# -------------------------------
PROD_DB_ENGINE=mysql
PROD_DB_NAME=your_prod_db_name
PROD_DB_USER=your_prod_db_user
PROD_DB_PASSWORD=your_prod_db_password
PROD_DB_HOST=your_prod_db_host
PROD_DB_PORT=3306
PROD_DB_SSL_CA=
PROD_DB_CONN_MAX_AGE=60

# Backward-compatible fallback keys (optional):
# DB_ENGINE=mysql
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=3306
# DB_SSL_CA=
# DB_CONN_MAX_AGE=60
